# Canonical production domain, used for sitemap.xml, robots.txt, and metadata.
NEXT_PUBLIC_SITE_URL="https://foundryhomes.nz"

# PostgreSQL connection string used by Prisma.
# Example: postgresql://user:password@localhost:5432/foundry_homes?schema=public
DATABASE_URL=""

# Blog admin login (single admin user, no user table).
ADMIN_PASSWORD=""
# Random secret used to sign admin session cookies. Generate with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=""

# Vercel Blob storage for blog image uploads (Storage tab in the Vercel
# dashboard -> Create Blob store -> connect to project; auto-populated in
# deployed environments). Optional in local dev: when unset, /api/upload
# falls back to saving files under public/assets/uploads/ instead.
BLOB_READ_WRITE_TOKEN=""

# Resend contact form email delivery.
RESEND_API_KEY=""
CONTACT_EMAIL_TO="hello@foundryhomes.co.nz"
# Optional later, after the sending domain is verified in Resend.
# CONTACT_EMAIL_FROM="Foundry Homes <enquiries@foundryhomes.co.nz>"
